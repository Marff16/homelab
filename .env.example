# Copy to .env and fill in your values.

# Your Tailscale machine IP (run: tailscale ip -4)
TAILSCALE_IP=

# Your Tailscale hostname (run: tailscale status --json | python3 -c "import sys,json; d=json.load(sys.stdin); print(d['Self']['DNSName'].rstrip('.'))")
TAILSCALE_HOST=

# Cert filenames inside APPS_ROOT/proxy/ (whatever name you used with tailscale cert)
TLS_CERT=
TLS_KEY=

# Your name, used for dashboard greetings
YOUR_NAME=

# Local timezone for containers (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=Europe/Berlin
